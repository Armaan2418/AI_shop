# Copy this file to .env and fill in your values
# In Railway: paste each of these as environment variables

# 🌐 SERVER
PORT=8000

# 🗄️ DATABASE
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/

# 📧 EMAIL
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password

# 🔐 JWT SECRETS (use long random strings in production)
EMAIL_TOKEN_SECRET=change_me_email
ACCESS_TOKEN_SECRET=change_me_access
REFRESH_TOKEN_SECRET=change_me_refresh
SECRET_KEY=change_me_secret

# 🤖 AI
GEMINI_API_KEY=your_gemini_api_key

# 🌍 PRODUCTION FRONTEND (your Vercel URL — no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
