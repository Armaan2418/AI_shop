# Copy this file to .env and fill in your values
# In Railway: paste each of these as environment variables in the dashboard

# 🌐 SERVER
PORT=8000

# 🗄️ DATABASE
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/

# 📧 EMAIL CONFIG (Brevo — https://app.brevo.com)
# Must use a Brevo-verified sender domain/email
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER=noreply@yourdomain.com

# 🔐 JWT SECRETS (use long random strings in production)
EMAIL_TOKEN_SECRET=change_me_email_secret
ACCESS_TOKEN_SECRET=change_me_access_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret
SECRET_KEY=change_me_secret

# 🤖 AI
GEMINI_API_KEY=your_gemini_api_key

# 🌍 PRODUCTION FRONTEND (your Vercel URL — no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
